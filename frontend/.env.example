# ─────────────────────────────────────────────────────────────
# Frontend Environment Variables
# ─────────────────────────────────────────────────────────────
#
# For LOCAL development:
#   Copy this file to .env.local and fill in values.
#   .env.local is git-ignored and never committed.
#
# For RAILWAY deployment:
#   Set these as environment variables in your Railway frontend service.
#   Dashboard → Your Frontend Service → Variables tab → Add variable
# ─────────────────────────────────────────────────────────────

# URL of the backend API server.
# Local dev: http://localhost:8080
# Production: https://your-backend-service.up.railway.app  (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8080
